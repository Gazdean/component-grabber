{
  "name": "component-grabber",
  "version": "1.0.0",
  "description": "A chrome extension that extract html and css for a selected component on a web page",
  "keywords": [
    "chrome",
    "extension",
    "component",
    "css",
    "html"
  ],
  "homepage": "https://github.com/Gazdean/component-grabber#readme",
  "bugs": {
    "url": "https://github.com/Gazdean/component-grabber/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gazdean/component-grabber.git"
  },
  "license": "ISC",
  "author": "Gareth Dean",
  "scripts": {
    "build": "webpack --config webpack.prod.ts",
    "start": "webpack --watch --config webpack.dev.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format-check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/chrome": "^0.1.37",
    "@types/eslint__js": "^8.42.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.0.3",
    "prettier": "3.8.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  }
}
