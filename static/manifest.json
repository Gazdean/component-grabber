{
  "manifest_version": 3,
  "name": "Component Grabber",
  "version": "0.1.0",
  "description": "A chrome extension that extract html and css for a selected component on a web page",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
